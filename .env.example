GITHUB_PERSONAL_ACCESS_TOKEN=   # Required — GitHub PAT with repo scope
GITHUB_OWNER=                   # Required — GitHub username or org (e.g. your-username)
GITHUB_REPO=                    # Required — Target repository name
MCP_AUTH_TOKEN=                  # Recommended — Random secret for Bearer token auth on MCP endpoints
PORT=5000                       # Optional, default 5000
